# Dependencies
node_modules/
.npm

# Environment variables - NEVER commit these
.env
.env.local
.env.production

# Logs
logs/
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Build outputs
dist/
build/

# IDE
.vscode/
.idea/
*.swp

# Temp files
tmp/
temp/

# Playwright artifacts
frontend/playwright-report/
frontend/test-results/
frontend/node_modules/

# Jest coverage
backend/coverage/

# Daily report outputs (generated files, not source)
# Use reports/* instead of reports/ so the specific file exceptions below work.
# Git cannot re-include a file if its parent directory is excluded.
reports/*
# Keep run history so the trend chart persists across CI runs
!reports/run-history.json
# Keep the web report directory so Vercel serves the daily report
!frontend/reports/
!frontend/reports/.gitkeep
!frontend/reports/daily-report.html
frontend/playwright-report-stage/
